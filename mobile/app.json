{
  "expo": {
    "name": "Health & Nutrition Control",
    "slug": "bienestarapp-mobile",
    "version": "0.1.0",
    "sdkVersion": "54.0.0",
    "scheme": "com.bienestarappmobile",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "orientation": "portrait",
    "icon": "./assets/Logo_p_bienestar.png",
    "android": {
      "package": "com.bienestarappmobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/Logo_p_bienestar.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "useNextNotificationsApi": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": {
            "scheme": "exp",
            "host": "192.168.100.27",
            "pathPrefix": "/--/oauth-callback"
          },
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "data": {
            "scheme": "com.bienestarappmobile"
          },
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "notification": {
      "icon": "./assets/Logo_p_bienestar.png",
      "color": "#9b59b6",
      "androidMode": "default",
      "androidCollapsedTitle": "Health & Nutrition Control"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/Logo_p_bienestar.png",
          "color": "#9b59b6",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "EXPO_PUBLIC_GEMINI_API_KEY": "AIzaSyDqSJeMrcbX4-tosZchFm-Vbz0jih6gJu0",
      "eas": {
        "projectId": "128cbc0f-4c59-41cb-9159-fde7782f3810"
      }
    }
  }
}
