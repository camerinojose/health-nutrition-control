# Backend Environment Variables - Example
# Copy this file to .env.local and fill in your values
# NEVER commit .env or .env.local to git!

# Server Configuration
PORT=8080
GIN_MODE=debug

# JWT Secret (REQUIRED - Change this in production!)
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=your-very-secure-jwt-secret-key-change-this-in-production

# Database Configuration
# For SQLite (Development)
DATABASE_PATH=./data.db

# For PostgreSQL (Production) - Uncomment and configure:
# DATABASE_URL=postgresql://username:password@localhost:5432/bienestarapp

# Google OAuth Configuration
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id-from-console.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth Redirect URIs
OAUTH_REDIRECT_URI_WEB=http://localhost:5174/oauth/callback
OAUTH_REDIRECT_URI_MOBILE=bienestarapp://oauth/callback

# CORS Configuration
CORS_ORIGINS=http://localhost:5174,http://localhost:5173,http://localhost:3000

# Gemini API (Optional - for AI features)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Production URLs (when deployed)
# OAUTH_REDIRECT_URI_WEB=https://your-frontend-domain.com/oauth/callback
# CORS_ORIGINS=https://your-frontend-domain.com
